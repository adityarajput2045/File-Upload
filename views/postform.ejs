<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post From</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="bg-dark text-white">
    <h1>Post Form</h1>
    <form method="post" action="/mypost" enctype="multipart/form-data">
  <div class="form-group">
    <label for="firtsname">firtsname</label>
    <input type="text" name="firtsname" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="firtsname">
    
  </div>
  <div class="form-group">
    <label for="lastname">lastname</label>
    <input type="text" name="lastname" class="form-control" id="exampleInputPassword1" placeholder="lastname">
  </div>
  <div class="form-group">
    <label for="samplefile">samplefile</label>
    <input type="file" name="samplefile" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="firtsname">
    
  </div>
  <button type="submit" class="btn btn-primary">Submit</button>
</form>
</body>
</html>